            "-- Localization",
            "-- **************************************************",
            "",
            "function ${1:ScriptName}:Localize(text)",
            "    local phrase = {}",
            "    -- English",
            "    local fileWord = MOHO.Localize(\"/Menus/File/File=File\")",
            "",
            "    --if fileWord == 'ملف' then",
            "        -- Arabic",
            "        ",
            "    --elseif fileWord == 'Dossier' then",
            "        -- Catalan",
            "        ",
