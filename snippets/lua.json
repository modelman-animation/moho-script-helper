{
    "Get Global Transform (With Camera)": {
        "prefix": "sn_layer_matrix&Cam",
        "body": [
            "local resultMatrix = LM.Matrix:new_local()",
            "resultMatrix:Identity()",
            "local nextLayer = ${1:moho.layer}",
            "local currentFrame = ${2:moho.frame}",
            "local currentDoc = ${3:moho.document}",
            "repeat",
            "\tlocal prevLayer = nextLayer",
            "\tlocal parentMatrix = LM.Matrix:new_local()",
            "\tnextLayer:GetLayerTransform(currentFrame, parentMatrix, currentDoc)",
            "\tparentMatrix:Multiply(resultMatrix)",
            "\tresultMatrix:Set(parentMatrix)",
            "\tif nextLayer:Parent() then nextLayer = nextLayer:Parent() end",
            "until nextLayer == prevLayer"
        ],
        "description": "Gets the full global transform of a layer including camera"
    },
    "Get Global Transform (Without Camera)": {
        "prefix": "sn_layer_matrixNoCam",
        "body": [
            "local resultMatrix = LM.Matrix:new_local()",
            "resultMatrix:Identity()",
            "local nextLayer = ${1:moho.layer}",
            "local currentFrame = ${2:moho.frame}",
            "local currentDoc = ${3:moho.document}",
            "repeat",
            "\tlocal prevLayer = nextLayer",
            "\tlocal parentMatrix = LM.Matrix:new_local()",
            "\tnextLayer:GetLayerTransform(currentFrame, parentMatrix, currentDoc)",
            "\tparentMatrix:Multiply(resultMatrix)",
            "\tresultMatrix:Set(parentMatrix)",
            "\tif nextLayer:Parent() then nextLayer = nextLayer:Parent() end",
            "until nextLayer == prevLayer",
            "",
            "local cameraMatrix = LM.Matrix:new_local()",
            "currentDoc:GetCameraMatrix(currentFrame, cameraMatrix)",
            "cameraMatrix:Invert()",
            "cameraMatrix:Multiply(resultMatrix)",
            "resultMatrix = cameraMatrix"
        ],
        "description": "Gets the global transform of a layer excluding camera"
    },
    "Get Bezier Handle Position": {
        "prefix": "sn_get_BezierHandlePos",
        "body": [
            "function GetBezierHandle(curve, pointID, frame, prePoint)",
            "\tlocal curvature = curve:GetCurvature(pointID, frame)",
            "\tlocal weight = curve:GetWeight(pointID, frame, prePoint)",
            "\tlocal offset = curve:GetOffset(pointID, frame, prePoint)",
            "\tlocal pointToRange = function(p)",
            "\t\tif curve.fClosed then",
            "\t\t\tif p < 0 then p = curve:CountPoints()-1 end",
            "\t\t\tif p >= curve:CountPoints() then p = 0 end",
            "\t\telse",
            "\t\t\tif p < 0 then p = 0 end",
            "\t\t\tif p >= curve:CountPoints() then p = curve:CountPoints()-1 end",
            "\t\tend",
            "\t\treturn p",
            "\tend",
            "\tlocal postPointID = pointToRange(pointID + 1)",
            "\tlocal prePointID = pointToRange(pointID - 1)",
            "\tlocal secondPointID = postPointID",
            "\tif prePoint then secondPointID = prePointID end",
            "\tif secondPointID == pointID then",
            "\t\treturn curve:Point(pointID).fAnimPos:GetValue(frame)",
            "\tend",
            "\tlocal N = curve:Point(postPointID).fAnimPos:GetValue(frame) - curve:Point(prePointID).fAnimPos:GetValue(frame)",
            "\tN:NormMe()",
            "\tif prePoint then N = N * -1 end",
            "\tlocal L = (curve:Point(secondPointID).fAnimPos:GetValue(frame) - curve:Point(pointID).fAnimPos:GetValue(frame)):Mag()",
            "\tL = L * curvature * weight",
            "\tlocal vec = N * L",
            "\tvec:Rotate(offset)",
            "\treturn curve:Point(pointID).fAnimPos:GetValue(frame) + vec",
            "end"
        ],
        "description": "Calculates Bezier handle position from curvature, weight and offset"
    },
    "Set Project to Image Size": {
        "prefix": "sn_doc_set_dim_image",
        "body": [
            "if (${1:moho.layer}:LayerType() == MOHO.LT_IMAGE) then",
            "\tlocal image = moho:LayerAsImage(${1:moho.layer})",
            "\tlocal width = image:PixelWidth()",
            "\tlocal height = image:PixelHeight()",
            "\t${2:moho.document}:SetShape(width, height)",
            "\tlocal source = image:SourceImage()",
            "\timage:SetSourceImage(source)",
            "end"
        ],
        "description": "Sets project dimensions to match the selected image layer"
    },
    "Loop All Layers": {
        "prefix": "sn_loop_layers",
        "body": [
            "local count = 0",
            "repeat",
            "\tlocal layer = moho.document:LayerByAbsoluteID(count)",
            "\tif layer then",
            "\t\tcount = count + 1",
            "\t\t$0",
            "\tend",
            "until not layer"
        ],
        "description": "Iterates through every layer in the document"
    },
    "Loop Points": {
        "prefix": "sn_loop_points",
        "body": [
            "local mesh = vectorLayer:Mesh()",
            "for i=0, mesh:CountPoints()-1 do",
            "\tlocal point = mesh:Point(i)",
            "\t$0",
            "end"
        ],
        "description": "Iterates through all points in a mesh"
    },
    "Loop Channels": {
        "prefix": "sn_loop_channels",
        "body": [
            "local chInfo  =  MOHO.MohoLayerChannel:new_local()",
            "for i = 0, moho.layer:CountChannels()-1 do",
            "\tmoho.layer:GetChannelInfo(i, chInfo)",
            "\tif not chInfo.selectionBased then",
            "\t\t${1:--channel logic}",
            "\tend",
            "end"
        ],
        "description": "Iterates through all channels in a layer"
    },
    "Loop Subchannels": {
        "prefix": "sn_loop_subchannels",
        "body": [
            "local chInfo  =  MOHO.MohoLayerChannel:new_local()",
            "for i = 0, moho.layer:CountChannels()-1 do",
            "\tmoho.layer:GetChannelInfo(i, chInfo)",
            "\tif not chInfo.selectionBased then",
            "\t\tfor j=0, chInfo.subChannelCount-1 do",
            "\t\t\tlocal subChannel = moho.layer:Channel(i, j, moho.document)",
            "\t\t\tlocal channel = nil",
            "\t\t\tif subChannel:ChannelType() == MOHO.CHANNEL_VAL then channel = moho:ChannelAsAnimVal(subChannel)",
            "\t\t\telseif subChannel:ChannelType() == MOHO.CHANNEL_VEC2 then channel = moho:ChannelAsAnimVec2(subChannel)",
            "\t\t\telseif subChannel:ChannelType() == MOHO.CHANNEL_VEC3 then channel = moho:ChannelAsAnimVec3(subChannel)",
            "\t\t\telseif subChannel:ChannelType() == MOHO.CHANNEL_BOOL then channel = moho:ChannelAsAnimBool(subChannel)",
            "\t\t\telseif subChannel:ChannelType() == MOHO.CHANNEL_COLOR then channel = moho:ChannelAsAnimColor(subChannel)",
            "\t\t\telseif subChannel:ChannelType() == MOHO.CHANNEL_STRING then channel = moho:ChannelAsAnimString(subChannel)",
            "\t\t\tend",
            "\t\t\t${1:--subchannel logic}",
            "\t\tend",
            "\tend",
            "end"
        ],
        "description": "Iterates through all subchannels in a layer"
    },
    "Loop Smartbone Actions": {
        "prefix": "sn_loop_smartbones",
        "body": [
            "local chInfo  =  MOHO.MohoLayerChannel:new_local()",
            "for i = 0, moho.layer:CountChannels()-1 do",
            "\tmoho.layer:GetChannelInfo(i, chInfo)",
            "\tif not chInfo.selectionBased then",
            "\t\tfor j=0, chInfo.subChannelCount-1 do",
            "\t\t\tlocal subChannel = moho.layer:Channel(i, j, moho.document)",
            "\t\t\tlocal channel = nil",
            "\t\t\tif subChannel:ChannelType() == MOHO.CHANNEL_VAL then channel = moho:ChannelAsAnimVal(subChannel)",
            "\t\t\telseif subChannel:ChannelType() == MOHO.CHANNEL_VEC2 then channel = moho:ChannelAsAnimVec2(subChannel)",
            "\t\t\telseif subChannel:ChannelType() == MOHO.CHANNEL_VEC3 then channel = moho:ChannelAsAnimVec3(subChannel)",
            "\t\t\telseif subChannel:ChannelType() == MOHO.CHANNEL_BOOL then channel = moho:ChannelAsAnimBool(subChannel)",
            "\t\t\telseif subChannel:ChannelType() == MOHO.CHANNEL_COLOR then channel = moho:ChannelAsAnimColor(subChannel)",
            "\t\t\telseif subChannel:ChannelType() == MOHO.CHANNEL_STRING then channel = moho:ChannelAsAnimString(subChannel)",
            "\t\t\tend",
            "\t\t\tlocal skel = moho.layer:ControllingSkeleton()",
            "\t\t\tfor a = 0, subChannel:CountActions()-1 do",
            "\t\t\t\tlocal actionSubChannel = subChannel:Action(a)",
            "\t\t\t\tlocal actionName = subChannel:ActionName(a)",
            "\t\t\t\tif skel then",
            "\t\t\t\t\tlocal smartBone = skel:BoneByName(actionName)",
            "\t\t\t\t\tif not smartBone and string.sub(actionName, -2) == \" 2\" then",
            "\t\t\t\t\t\tsmartBone = skel:BoneByName(string.sub(actionName, 1, -3))",
            "\t\t\t\t\tend",
            "\t\t\t\t\tif smartBone then",
            "\t\t\t\t\t\tlocal smartBoneChannel = moho:ChannelAsAnimVal(smartBone.fAnimAngle:ActionByName(actionName))",
            "\t\t\t\t\t\tlocal currentSmartBoneVal = smartBone.fAnimAngle:GetValue(moho.frame)",
            "\t\t\t\t\t\t${1:--smartbone logic}",
            "\t\t\t\t\tend",
            "\t\t\t\tend",
            "\t\t\tend",
            "\t\tend",
            "\tend",
            "end"
        ],
        "description": "Iterates through all smart bone actions in a layer"
    },
    "Full Menu Script Template": {
