            "-- **************************************************",
            "-- Dialog",
            "-- **************************************************",
            "",
            "local ${1:ScriptName}Dialog = {}",
            "",
            "function ${1:ScriptName}Dialog:new(moho)",
            "    local d = LM.GUI.SimpleDialog('${1:ScriptName}', ${1:ScriptName}Dialog)",
            "    d.moho = moho",
            "    local l = d:GetLayout()",
            "",
            "    local msg = MOHO.MSG_BASE",
            "    local function msgnew()",
            "        msg = msg + 1",
            "        return msg",
            "    end",
            "",
            "    -- Add your UI elements here",
            "    ",
            "    return d",
            "end",
            "",
            "function ${1:ScriptName}Dialog:UpdateWidgets()",
            "    -- Update UI elements with loaded values",
            "end",
            "",
            "function ${1:ScriptName}Dialog:HandleMessage(msg)",
            "    -- Handle UI messages",
            "end",
            "",
            "function ${1:ScriptName}Dialog:OnValidate()",
            "    return true",
            "end",
            "",
            "function ${1:ScriptName}Dialog:OnOK()",
            "    -- Save values from UI",
            "end",
            "",
            "-- **************************************************",
            "-- The guts of this script",
            "-- **************************************************",
            "",
            "function ${1:ScriptName}:Run(moho)",
            "    local dlog = ${1:ScriptName}Dialog:new(moho)",
            "    if (dlog:DoModal() == LM.GUI.MSG_CANCEL) then",
            "        return",
            "    end",
            "    ",
            "    moho.document:SetDirty()",
            "    moho.document:PrepUndo(nil)",
            "    ",
            "    -- Your code here",
            "    ${2:}",
            "",
            "    moho:UpdateUI()",
            "end",
            "",
