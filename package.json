{
  "name": "moho-script-helper",
  "displayName": "Moho Script Helper",
  "description": "Lua autocomplete and stubs for Moho scripting",
  "version": "1.1.0",
  "publisher": "Modelman",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/modelman-animation/moho-script-helper.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configurationDefaults": {
      "Lua.completion.callSnippet": "Replace",
      "Lua.diagnostics.disable": ["inject-field"]
    },
    "snippets": [
      {
        "language": "lua",
        "path": "./snippets/moho-snippets.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}